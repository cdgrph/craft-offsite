{% import '_includes/forms' as forms %}

{% set overrideWarning = 'This is being overridden by the `%s` setting in `config/offsite.php`.' %}

<p class="notice with-icon">
    Settings saved here are stored in project config and propagate to other
    environments on deploy. Connection and notification fields only accept
    environment variable references such as <code>$OFFSITE_BUCKET</code>; put
    their real values in <code>.env</code>. Leave the access key fields blank
    to use the AWS SDK default credential provider chain. Any key set in
    <code>config/offsite.php</code> always overrides its CP value.
</p>

<h2>S3 Connection</h2>

{{ forms.autosuggestField({
    label: 'S3 Endpoint URL',
    instructions: 'Environment variable containing the S3-compatible endpoint URL.',
    id: 'endpoint',
    name: 'endpoint',
    value: settings.cpDisplayValue('endpoint'),
    suggestEnvVars: true,
    placeholder: '$OFFSITE_ENDPOINT',
    disabled: 'endpoint' in overriddenFields,
    warning: 'endpoint' in overriddenFields ? overrideWarning|format('endpoint') : null,
    errors: settings.getErrors('endpoint'),
}) }}

{{ forms.autosuggestField({
    label: 'Region',
    instructions: 'Environment variable containing the S3 region. Required when no custom endpoint is set.',
    id: 'region',
    name: 'region',
    value: settings.cpDisplayValue('region'),
    suggestEnvVars: true,
    placeholder: '$OFFSITE_REGION',
    disabled: 'region' in overriddenFields,
    warning: 'region' in overriddenFields ? overrideWarning|format('region') : null,
    errors: settings.getErrors('region'),
}) }}

{{ forms.autosuggestField({
    label: 'Bucket',
    instructions: 'Environment variable containing the S3 bucket name.',
    id: 'bucket',
    name: 'bucket',
    value: settings.cpDisplayValue('bucket'),
    suggestEnvVars: true,
    placeholder: '$OFFSITE_BUCKET',
    required: 'bucket' not in overriddenFields,
    disabled: 'bucket' in overriddenFields,
    warning: 'bucket' in overriddenFields ? overrideWarning|format('bucket') : null,
    errors: settings.getErrors('bucket'),
}) }}

{{ forms.autosuggestField({
    label: 'Key Prefix',
    instructions: 'Environment variable containing the optional S3 object key prefix.',
    id: 'keyPrefix',
    name: 'keyPrefix',
    value: settings.cpDisplayValue('keyPrefix'),
    suggestEnvVars: true,
    placeholder: '$OFFSITE_KEY_PREFIX',
    disabled: 'keyPrefix' in overriddenFields,
    warning: 'keyPrefix' in overriddenFields ? overrideWarning|format('keyPrefix') : null,
    errors: settings.getErrors('keyPrefix'),
}) }}

{{ forms.autosuggestField({
    label: 'Access Key ID',
    instructions: 'Environment variable containing the access key ID. Leave blank to use the AWS SDK credential provider chain.',
    id: 'accessKey',
    name: 'accessKey',
    value: settings.cpDisplayValue('accessKey'),
    suggestEnvVars: true,
    placeholder: '$OFFSITE_ACCESS_KEY',
    disabled: 'accessKey' in overriddenFields,
    warning: 'accessKey' in overriddenFields ? overrideWarning|format('accessKey') : null,
    errors: settings.getErrors('accessKey'),
}) }}

{{ forms.autosuggestField({
    label: 'Secret Access Key',
    instructions: 'Environment variable containing the secret access key. Leave blank to use the AWS SDK credential provider chain.',
    id: 'secretKey',
    name: 'secretKey',
    value: settings.cpDisplayValue('secretKey'),
    suggestEnvVars: true,
    placeholder: '$OFFSITE_SECRET_KEY',
    disabled: 'secretKey' in overriddenFields,
    warning: 'secretKey' in overriddenFields ? overrideWarning|format('secretKey') : null,
    errors: settings.getErrors('secretKey'),
}) }}

<hr>

<h2>Retention</h2>

{{ forms.selectField({
    label: 'Retention Mode',
    instructions: 'How old backup generations get deleted. Plugin pruning requires S3 delete permission; lifecycle mode never deletes anything, so create a bucket lifecycle rule or generations accumulate without limit.',
    id: 'retentionMode',
    name: 'retentionMode',
    options: [
        { label: 'The plugin prunes generations beyond the keep count', value: 'plugin' },
        { label: 'A bucket lifecycle rule prunes old generations', value: 'lifecycle' },
    ],
    value: settings.retentionMode,
    toggle: true,
    targetPrefix: '.retention-',
    disabled: 'retentionMode' in overriddenFields,
    warning: 'retentionMode' in overriddenFields ? overrideWarning|format('retentionMode') : null,
    errors: settings.getErrors('retentionMode'),
}) }}

<div class="retention-plugin{% if settings.retentionMode != 'plugin' %} hidden{% endif %}">
    {{ forms.textField({
        label: 'Generations to Keep',
        id: 'retentionKeepCount',
        name: 'retentionKeepCount',
        type: 'number',
        min: 1,
        step: 1,
        required: true,
        value: settings.retentionKeepCount,
        disabled: 'retentionKeepCount' in overriddenFields,
        warning: 'retentionKeepCount' in overriddenFields ? overrideWarning|format('retentionKeepCount') : null,
        errors: settings.getErrors('retentionKeepCount'),
    }) }}
</div>

<hr>

<h2>Runtime</h2>

{{ forms.textField({
    label: 'Minimum Free Disk Space (MB)',
    instructions: 'The backup run aborts before starting if the work directory has less free space than this. Budget roughly 3× your uncompressed dump size.',
    id: 'minFreeDiskMb',
    name: 'minFreeDiskMb',
    type: 'number',
    min: 1,
    step: 1,
    required: true,
    value: settings.minFreeDiskMb,
    disabled: 'minFreeDiskMb' in overriddenFields,
    warning: 'minFreeDiskMb' in overriddenFields ? overrideWarning|format('minFreeDiskMb') : null,
    errors: settings.getErrors('minFreeDiskMb'),
}) }}

{{ forms.textField({
    label: 'Multipart Upload Threshold (MB)',
    instructions: 'Files larger than this use S3 multipart upload. S3 requires parts of at least 5 MB.',
    id: 'multipartThresholdMb',
    name: 'multipartThresholdMb',
    type: 'number',
    min: 5,
    step: 1,
    required: true,
    value: settings.multipartThresholdMb,
    disabled: 'multipartThresholdMb' in overriddenFields,
    warning: 'multipartThresholdMb' in overriddenFields ? overrideWarning|format('multipartThresholdMb') : null,
    errors: settings.getErrors('multipartThresholdMb'),
}) }}

